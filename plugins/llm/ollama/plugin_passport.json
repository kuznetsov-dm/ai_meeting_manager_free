  "features": [
    "Local processing - no data sent to external servers",
    "Multiple model support",
    "Automatic model downloading",
    "Server management (start/stop/check)",
    "Model management (list/pull/remove)",
    "Custom system prompts",
    "Configurable temperature and token limits"
  ],
  "capabilities": {
    "alias_code_policy": {
      "provider_code": "ol"
    },
    "health": {
      "server": {
        "auto_start_action": "start_server"
      },
      "models": {
        "require_installed_list": true
      }
    },
    "models": {
      "storage": "local",
      "selection_requires_installed": true,
      "managed_actions": {
        "list": "list_models",
        "pull": "pull_model",
        "remove": "remove_model",
        "test": "test_model",
        "test_connection": "test_connection"
      }
    }
  },
  "requirements": [
    "Ollama server installed and running",
    "At least 8GB RAM for larger models",
    "Sufficient disk space for model downloads (2-20GB depending on model)"
  ]
}
