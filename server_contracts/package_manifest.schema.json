{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://apogee.ai/aimn/server_contracts/package_manifest.schema.json",
  "title": "AIMN Package Manifest",
  "type": "object",
  "required": ["plugin_id", "version", "api_version", "entrypoint", "files"],
  "properties": {
    "plugin_id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_]*(\\.[a-z0-9_]+)+$"
    },
    "version": {
      "type": "string",
      "minLength": 1
    },
    "api_version": {
      "type": "string",
      "const": "1"
    },
    "entrypoint": {
      "type": "string",
      "pattern": "^[A-Za-z_][A-Za-z0-9_\\.]*:[A-Za-z_][A-Za-z0-9_]*$"
    },
    "publisher_id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_\\-]*$"
    },
    "package_checksum_sha256": {
      "type": "string",
      "pattern": "^[a-fA-F0-9]{64}$"
    },
    "signature": {
      "type": "string"
    },
    "signature_algorithm": {
      "type": "string",
      "enum": ["rsa-sha256"]
    },
    "signing_key_id": {
      "type": "string"
    },
    "files": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["path", "sha256"],
        "properties": {
          "path": {
            "type": "string",
            "minLength": 1
          },
          "sha256": {
            "type": "string",
            "pattern": "^[a-fA-F0-9]{64}$"
          },
          "size_bytes": {
            "type": "integer",
            "minimum": 0
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
